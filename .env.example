# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# When adding additional environment variables, update the schema in "src/env.js".

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:pass@localhost:5432/nevali-cosmetics?connection_limit=5"

# Better Auth — generate secret with: npx @better-auth/cli@latest secret
BETTER_AUTH_SECRET="your-generated-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3000"

# Email verification (Better Auth). When true, users must verify email before password sign-in.
# Requires RESEND_API_KEY (and ideally RESEND_FROM_EMAIL on a verified domain) in production.
# First seeded / bootstrapped superadmin is still marked emailVerified in the signup hook.
# REQUIRE_EMAIL_VERIFICATION="true"

# Resend — verification + transactional mail. https://resend.com/api-keys
# Without RESEND_API_KEY, outbound mail is skipped (fine for local dev).
RESEND_API_KEY="re_..."
# RESEND_FROM_EMAIL="noreply@yourdomain.com"

# Optional CC: internal visibility on each new RFQ thread message email.
# RFQ_THREAD_CC_EMAIL="ops@yourdomain.com"

# Optional CC: procurement / shared inbox on buyer inquiry receipts and buyer-facing RFQ updates.
# BUYER_ENTERPRISE_INQUIRY_CC_EMAIL="buying-team@yourdomain.com"

# Unread alerts digest (optional). POST /api/cron/notifications-digest with header:
#   Authorization: Bearer <same value>   OR   x-cron-secret: <same value>
# Example: curl -X POST -H "Authorization: Bearer $NOTIFICATION_DIGEST_CRON_SECRET" https://your-host/api/cron/notifications-digest
# NOTIFICATION_DIGEST_CRON_SECRET="long-random-string-for-cron-only"

# Optional label shown on /contact near privacy & terms summaries (informational only).
# LEGAL_POLICY_EFFECTIVE_DATE="2026-04-01"

# Stripe — reserved for future embedded checkout (not wired to inquiry-first flows yet).
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Supabase — media uploads (profile pictures, product images). Public bucket required for display URLs.
# https://supabase.com/dashboard/project/_/storage/buckets
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_STORAGE_BUCKET="nevali-cosmetics-media"
# NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"

# Public contact email on /contact (mailto). Optional; UI may fall back to a default.
# CONTACT_PUBLIC_EMAIL="hello@yourdomain.com"

# Shown on public product CTAs (optional extra line for operators).
# NEXT_PUBLIC_MARKETPLACE_BILLING_NOTE="Invoices flow through your ERP reference ABC."
