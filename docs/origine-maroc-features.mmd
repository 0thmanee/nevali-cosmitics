  subgraph PROD["🌿 Partner portal `/producer`"]
    direction TB
    subgraph PD["Dashboard & layout"]
      PD1["Dashboard overview + stats (RFQs, support, products)"]
      PD2["Sidebar nav · org context · Add Product → `/products/new`"]
      PD3["Header: notifications placeholder · Log out"]
      PD4["Logo → home `/`"]
    end
    subgraph PP["Profile"]
      PP1["Profile view + edit"]
      PP2["Partner status card · certificate download `/api/certificate`"]
      PP3["Documents card → live certifications list + link to Certification page"]
    end
    subgraph PPR["Products"]
      PPR1["List · create · detail · edit"]
      PPR2["Images upload (Supabase)"]
      PPR3["Certifications per product (upload PDF/image)"]
    end
    subgraph PCERT["Certification hub"]
      PC1["Global org certifications"]
      PC2["Standards grid · certified products table"]
    end
    subgraph PTR["Training"]
      PT1["Program catalog · enrollment · progress"]
      PT2["Program detail (modules, media consumption)"]
    end
    subgraph PCOM["Commercial"]
      PCOM1["RFQs list · status"]
      PCOM2["Contracts list · progress · deliveries"]
    end
    subgraph PSUP["Support"]
      PS1["Tickets: create · list · thread"]
    end
  end

  %% ========== ADMIN ==========
  subgraph ADM["⚙️ Admin `/admin`"]
    direction TB
    subgraph AD0["Scope & layout"]
      AD01["Organization filter `?org=slug` · All orgs"]
      AD02["Nav badges scoped by org"]
      AD03["Superadmin badge · user block · Log out · Logo → home"]
    end
    subgraph AD1["Operations"]
      AD11["Dashboard overview + quick actions (org-aware)"]
      AD12["Partners: paginated list · approve · edit · delete · detail"]
      AD13["Products: list · tabs · approve / reject · detail"]
      AD14["Certifications: list · approve / reject"]
      AD15["Training: CRUD programs · modules · media"]
      AD16["Support: tickets · status · admin notes · history"]
      AD17["Contracts & RFQs: lists · cancel RFQ · complete contract"]
    end
  end

  %% ========== API & DATA ==========
  subgraph API["📡 Server actions & APIs"]
    direction TB
    AP1["Products · Certifications · Partners"]
    AP2["Training · Contracts / RFQs · Support"]
    AP3["Profile · Dashboard stats · Admin (orgs, nav stats)"]
    AP4["Media upload route · Certificate PDF route"]
    AP5["Auth handler `[...all]`"]
  end

  %% ========== DATA LAYER ==========
  subgraph DATA["🗄️ Data & storage"]
    direction TB
    D1["PostgreSQL + Prisma"]
    D2["Models: User · Profile · Organization · Member · Invitation"]
    D3["Product · ProductImage · Certification"]
    D4["TrainingProgram · Module · Media · Enrollment"]
    D5["Rfq · Contract · SupportTicket + StatusEvent"]
    D6["Supabase Storage (images, certs, training media)"]
  end

  %% ========== ROADMAP ==========
  subgraph FUT["🔜 To add / beat competitors"]
    direction TB
    F1["Dedicated buyer portal & discovery (today: RFQ/contract as records)"]
    F2["Payments: escrow · milestones · invoicing (Stripe Connect / partner)"]
    F3["KYC/KYB & third-party inspection hooks (SGS/BV-style)"]
    F4["Public verify: QR / lot ID → approved certs + trace metadata"]
    F5["Deep traceability: batch, harvest, IoT hooks, blockchain audit optional"]
    F6["Notifications: in-app + email (replace header bell placeholder)"]
    F7["i18n · market pricing intel · AI translation"]
    F8["Institutional tie-ins: Foodex missions · ePhyto readiness UX"]
    F9["Mobile / PWA · offline-first producer workflows"]
  end

