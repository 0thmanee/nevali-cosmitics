  end

  %% ========== PUBLIC ==========
  subgraph PUB["🌐 Public marketing site"]
    direction TB
    P1["Landing & brand narrative"]
    P2["Sections: Trust · Features · FAQ · Ecosystem · etc."]
    P3["Public navigation & CTAs to auth"]
  end

  %% ========== AUTH & ACCESS ==========
  subgraph AUTH["🔐 Authentication & access"]
    direction TB
    A1["Register / Login (Better Auth)"]
    A2["Email verification"]
    A3["Session + Organization plugin (tenant)"]
    A4["Roles: partner · superadmin"]
    A5["Pending approval gate (disabled → enabled)"]
    A6["Onboarding: profile form → organization + Member"]
  end

